+    std::optional<float> max_temp;
+    std::optional<float> max_target;
+    std::optional<float> max_humidity;
+
+    for (auto it = notification.begin(); it != notification.end(); ++it) {
+        if (!it->is_object()) {
+            continue;
+        }
+        const std::string& key = it.key();
+        const bool is_heater =
+            key.rfind(kHappyHareHeaterPrefix, 0) == 0 &&
+            key.find("_heater") != std::string::npos;
+        const bool is_aht = key.rfind(kAht20Prefix, 0) == 0;
+        const bool is_env =
+            key.rfind(kHappyHareEnvPrefix, 0) == 0 &&
+            key.find("_env") != std::string::npos;
+        if (!is_heater && !is_aht && !is_env) {
+            continue;
+        }
+        if (auto t_it = it->find("temperature");
+            t_it != it->end() && t_it->is_number()) {
+            const float v = t_it->get<float>();
+            if (!max_temp || v > *max_temp) {
+                max_temp = v;
+            }
+        }
+        if (is_heater) {
+            if (auto target_it = it->find("target");
+                target_it != it->end() && target_it->is_number()) {
+                const float v = target_it->get<float>();
+                if (!max_target || v > *max_target) {
+                    max_target = v;
+                }
+            }
+        }
+        if (is_aht || is_env) {
+            if (auto h_it = it->find("humidity");
+                h_it != it->end() && h_it->is_number()) {
+                const float v = h_it->get<float>();
+                if (!max_humidity || v > *max_humidity) {
+                    max_humidity = v;
+                }
+            }
+        }
+    }
+
+    if (!max_temp && !max_target && !max_humidity) {
+        return false;
+    }
+
+    if (system_info_.units.empty()) {
+        return false;
+    }
+
+    auto& env = system_info_.units[0].environment;
+    if (!env) {
+        env = EnvironmentData{};
+    }
+    if (max_temp) {
+        env->temperature_c = *max_temp;
+        dryer_info_.current_temp_c = *max_temp;
+    }
+    if (max_target) {
+        dryer_info_.target_temp_c = *max_target;
+        dryer_info_.active = *max_target > 0.0f;
+    }
+    if (max_humidity) {
+        env->humidity_pct = *max_humidity;
+        env->has_humidity = true;
     }

-    emit_event(EVENT_STATE_CHANGED);
+    return true;
