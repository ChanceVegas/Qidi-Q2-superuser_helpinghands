+bool AmsBackendHappyHare::apply_qidi_box_environment_status(
+    const nlohmann::json& notification) {
+    constexpr std::string_view kHappyHareHeaterPrefix = "heater_generic box";
+    constexpr std::string_view kAht20Prefix = "aht20_f heater_box";
+    constexpr std::string_view kHappyHareEnvPrefix = "temperature_sensor box";

-    {
